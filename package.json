{
  "name": "codepulse-desktop",
  "private": true,
  "version": "1.3.3",
  "description": "CodePulse Desktop / 码脉桌面端 — local AI coding-agent status hub",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @codepulse/desktop dev",
    "build": "pnpm -r --filter ./packages/* build && pnpm --filter @codepulse/desktop build",
    "build:packages": "pnpm -r --filter ./packages/* build",
    "dist": "pnpm --filter @codepulse/desktop dist",
    "dist:win": "pnpm --filter @codepulse/desktop dist:win",
    "dist:linux": "pnpm --filter @codepulse/desktop dist:linux",
    "dist:mac": "pnpm --filter @codepulse/desktop dist:mac",
    "dist:mac:arm64": "pnpm --filter @codepulse/desktop dist:mac:arm64",
    "dist:mac:x64": "pnpm --filter @codepulse/desktop dist:mac:x64",
    "typecheck": "pnpm -r typecheck && tsc --noEmit -p tests/tsconfig.json",
    "pretest": "npm rebuild better-sqlite3",
    "test": "node tests/run-tests.mjs",
    "smoke": "node scripts/run-smoke.mjs",
    "lint": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:generate": "pnpm --filter @codepulse/storage db:generate"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.21.5",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "ws": "^8.18.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@serialport/bindings-cpp",
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.19.0"
}
