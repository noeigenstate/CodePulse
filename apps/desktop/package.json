{
  "name": "@codepulse/desktop",
  "version": "1.3.1",
  "private": true,
  "description": "CodePulse Desktop Electron app",
  "main": "./out/main/index.js",
  "author": "CodePulse",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "dist": "electron-vite build && electron-builder",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:linux": "electron-vite build && electron-builder --linux AppImage --x64",
    "dist:mac": "electron-vite build && electron-builder --mac --arm64 --x64",
    "dist:mac:arm64": "electron-vite build && electron-builder --mac --arm64",
    "dist:mac:x64": "electron-vite build && electron-builder --mac --x64",
    "dist:dir": "electron-vite build && electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "@codepulse/adapters": "workspace:*",
    "@codepulse/core": "workspace:*",
    "@codepulse/local-server": "workspace:*",
    "@codepulse/shared": "workspace:*",
    "@codepulse/storage": "workspace:*",
    "@fastify/websocket": "^11.0.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "bonjour-service": "^1.4.3",
    "drizzle-orm": "^0.38.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "fastify": "^5.2.1",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.11",
    "zustand": "^5.0.2"
  }
}
